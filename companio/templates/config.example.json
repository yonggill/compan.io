{
  "agents": {
    "defaults": {
      "workspace": "~/.companio/workspace",
      "model": "anthropic/claude-opus-4-5",
      "provider": "auto",
      "maxTokens": 8192,
      "temperature": 1,
      "maxToolIterations": 40,
      "memoryWindow": 200,
      "reasoningEffort": "medium"
    }
  },
  "providers": {
    "anthropic": {
      "apiKey": ""
    },
    "openai": {
      "apiKey": ""
    },
    "gemini": {
      "apiKey": ""
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": false,
    "telegram": {
      "enabled": false,
      "token": "",
      "allowFrom": [],
      "proxy": null,
      "replyToMessage": false
    }
  },
  "tools": {
    "restrictToWorkspace": true,
    "web": {
      "proxy": null,
      "search": {
        "apiKey": "",
        "maxResults": 5
      }
    },
    "exec": {
      "timeout": 60,
      "pathAppend": ""
    },
    "obsidian": {
      "enabled": false,
      "vaultPath": ""
    },
    "mcpServers": {}
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790,
    "heartbeat": {
      "enabled": true,
      "intervalS": 600
    }
  }
}
